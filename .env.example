# Session cookie signing key — python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-random-32-char-string

# Fernet key for encrypting stored TOTP secrets — generate once with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-fernet-key

# Bootstrap admin — created on first run, owns any pre-existing surveys.
# After first login this account must enrol in 2FA like everyone else.
ADMIN_EMAIL=admin@survey.local
ADMIN_PASSWORD=replace-with-strong-password

DB_PATH=/data/survey.db
